# Supabase public browser config
# Use these locally, or add them as GitHub Actions repository secrets for GitHub Pages.
# These are public anon browser values only. Never use the Supabase service_role key in frontend code.

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# Static browser config fallback used by chalets-supabase-config.js
CHALETS_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
CHALETS_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_PUBLIC_KEY

# ===========================================================================
# SERVER-SIDE ONLY — set via `supabase secrets set`, NEVER in the browser/repo.
# These are documented here as NAMES only (no real values are ever committed).
# ===========================================================================

# Payments (create-payment-session / payment-webhook Edge Functions)
APP_ENV=staging                       # test|staging enable the test adapter; production blocks it
PAYMENT_PROVIDER=                      # e.g. moyasar|tap|hyperpay (real) or test (non-prod only)
PAYMENT_PROVIDER_API_BASE=
PAYMENT_PROVIDER_SECRET_KEY=
PAYMENT_PROVIDER_PUBLISHABLE_KEY=
PAYMENT_WEBHOOK_SECRET=
PAYMENTS_ALLOW_PARTIAL=false
PAYMENTS_ALLOW_TEST_PROVIDER=false

# Chalet Brain assistant (chalet-assistant / chalet-autopilot Edge Functions)
# Model note: deepseek-chat/deepseek-reasoner are deprecated 2026-07-24;
# current models are deepseek-v4-flash / deepseek-v4-pro.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
ASSISTANT_CONFIRM_SECRET=             # HMAC key for confirmation tokens

# Official WhatsApp (optional; automatic sending stays OFF until these are set)
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_ID=
